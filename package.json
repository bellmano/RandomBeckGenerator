{
  "name": "randombeckgenerator",
  "version": "1.0.0",
  "description": "A website that helps you choose a random Beck movie to watch. Perfect for when you can't decide which Beck film to enjoy!",
  "scripts": {
    "test": "jest",
    "test:coverage": "jest --coverage",
    "fetch:ratings": "node src/fetchRatings.js"
  },
  "devDependencies": {
    "jest": "^30.4.2",
    "jest-environment-jsdom": "^30.4.1"
  },
  "jest": {
    "testEnvironment": "jsdom",
    "collectCoverageFrom": [
      "src/script.js",
      "src/fetchRatings.js"
    ],
    "coverageDirectory": "coverage",
    "coverageReporters": ["text", "lcov", "html"],
    "coveragePathIgnorePatterns": [
      "/node_modules/",
      "/tests/"
    ],
    "transform": {}
  }
}
